async function loadCRM() {
  try {
    setSyncStatus('syncing', 'Cargando...');
    const data = await sbFetch('gira_empresas?order=empresa.asc&limit=1000');
    if (data && data.length > 0) {
      crmData = data;
      setSyncStatus('ok', 'Sincronizado');
    } else {
      // Primera vez: seed con datos iniciales
      await seedCRM();
    }
  } catch(e) {
    setSyncStatus('error', 'Sin conexión');
    // Fallback a localStorage
    const s = localStorage.getItem('gira_crm_v1');
    crmData = s ? JSON.parse(s) : RAW_DATA.map((c,i) => ({...c, id: i}));
    toast('Usando datos locales (sin conexión)', 'err');
  }
  applyFilters();
  updateStats();
}

async function seedCRM() {
  setSyncStatus('syncing', 'Importando datos...');
  // Insert in batches of 50
  const batch = 50;
  for (let i = 0; i < RAW_DATA.length; i += batch) {
    await sbFetch('gira_empresas', {
      method: 'POST',
      prefer: 'return=minimal',
      body: RAW_DATA.slice(i, i+batch)
    });
  }
  const data = await sbFetch('gira_empresas?order=empresa.asc&limit=1000');
  crmData = data || [];
  setSyncStatus('ok', 'Datos importados ✓');
  toast('¡297 empresas importadas correctamente!', 'ok');
}

async function saveCompanyDB(obj) {
  try {
    setSyncStatus('syncing', 'Guardando...');
    if (editingId !== null) {
      await sbFetch('gira_empresas?id=eq.' + editingId, {
        method: 'PATCH',
        prefer: 'return=minimal',
        body: obj
      });
      const idx = crmData.findIndex(c => c.id === editingId);
      if (idx >= 0) crmData[idx] = {...obj, id: editingId};
    } else {
      const res = await sbFetch('gira_empresas', {
        method: 'POST',
        body: obj
      });
      if (res && res[0]) crmData.push(res[0]);
    }
    setSyncStatus('ok', 'Guardado ✓');
    toast('Empresa guardada', 'ok');
  } catch(e) {
    setSyncStatus('error', 'Error al guardar');
    toast('Error al guardar: ' + e.message, 'err');
  }
}

async function deleteCompanyDB(id) {
  try {
    await sbFetch('gira_empresas?id=eq.' + id, { method: 'DELETE', prefer: 'return=minimal' });
    crmData = crmData.filter(c => c.id !== id);
    setSyncStatus('ok', 'Sincronizado');
    toast('Empresa eliminada');
  } catch(e) {
    toast('Error al eliminar', 'err');
  }
}

