async function loadEvents() {
  try {
    const data = await sbFetch('gira_eventos?order=created_at.desc&limit=200');
    eventsData = (data || []).map(e => ({
      ...e,
      checklist: e.checklist || [],
      cronoInterno: e.crono_interno || [],
      cronoCliente: e.crono_cliente || [],
      proveedores: e.proveedores || [],
      sheets: e.sheets || []
    }));
  } catch(e) {
    const s = localStorage.getItem('gira_events_v1');
    eventsData = s ? JSON.parse(s) : [];
  }
}

async function saveEventDB(ev) {
  try {
    setSyncStatus('syncing', 'Guardando...');
    const payload = {
      nombre: ev.nombre,
      empresa: ev.empresa || '',
      fecha: ev.fecha || null,
      estado: ev.estado,
      descripcion: ev.descripcion || '',
      notas: ev.notas || '',
      checklist: ev.checklist || [],
      crono_interno: ev.cronoInterno || [],
      crono_cliente: ev.cronoCliente || [],
      proveedores: ev.proveedores || [],
      sheets: ev.sheets || []
    };
    if (ev.id) {
      await sbFetch('gira_eventos?id=eq.' + ev.id, {
        method: 'PATCH',
        prefer: 'return=minimal',
        body: payload
      });
    } else {
      const res = await sbFetch('gira_eventos', { method: 'POST', body: payload });
      if (res && res[0]) ev.id = res[0].id;
    }
    setSyncStatus('ok', 'Guardado ✓');
  } catch(e) {
    setSyncStatus('error', 'Error');
    toast('Error al guardar evento', 'err');
  }
}

async function deleteEventDB(id) {
  try {
    await sbFetch('gira_eventos?id=eq.' + id, { method: 'DELETE', prefer: 'return=minimal' });
  } catch(e) { toast('Error al eliminar', 'err'); }
}

