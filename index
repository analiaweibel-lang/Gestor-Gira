  // blank
  return `
    <div class="section-label">Hoja libre</div>
    <textarea class="notas-area" style="min-height:300px;font-size:14px;line-height:1.8;"
      placeholder="Escribí lo que necesites: ideas, presupuesto rápido, contactos..."
      oninput="saveBlankSheet(${sheetIdx},this.value)">${sheet.content||''}</textarea>`;
