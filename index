<!DOCTYPE html> 
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gira Eventos — Sistema de Gestión</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap');
  :root {
    --bg: #f0f8fd;
    --surface: #ffffff;
    --surface2: #f4fafd;
    --surface3: #e6f4fb;
    --border: #cce8f5;
    --brand: #00b4d8;
    --brand2: #0090b0;
    --brand-dim: rgba(0,180,216,0.10);
    --text: #0d1f2d;
    --text2: #3a6070;
    --text3: #7aaabb;
    --red: #c0392b;
    --green: #1a9e5c;
    --blue: #0077a8;
    --orange: #e07c2b;
    --purple: #6c3acd;
  }
  * { box-sizing:border-box; margin:0; padding:0; }
  body { font-family:'DM Sans',sans-serif; background:var(--bg); color:var(--text); min-height:100vh; overflow-x:hidden; }

  /* HEADER */
  header { display:flex; align-items:center; justify-content:space-between; padding:12px 28px; background:#fff; border-bottom:2px solid var(--brand); position:sticky; top:0; z-index:100; box-shadow:0 2px 12px rgba(0,180,216,0.10); }
  .logo-wrap { display:flex; align-items:center; gap:10px; }
  .logo-wrap img { height:38px; width:38px; object-fit:contain; }
  .logo-name { font-family:'DM Serif Display',serif; font-size:20px; color:var(--brand); letter-spacing:.5px; }
  .logo-sub { color:var(--text2); font-size:12px; margin-left:6px; font-weight:300; }

  nav { display:flex; gap:6px; }
  nav button { background:none; border:1px solid transparent; color:var(--text2); padding:8px 16px; border-radius:8px; cursor:pointer; font-family:'DM Sans',sans-serif; font-size:14px; font-weight:500; transition:all .2s; }
  nav button:hover { color:var(--text); background:var(--surface2); }
  nav button.active { color:var(--brand); border-color:var(--brand-dim); background:var(--brand-dim); }

  /* SYNC BADGE */
  .sync-badge { display:flex; align-items:center; gap:6px; font-size:12px; color:var(--text3); padding:6px 12px; background:var(--surface2); border-radius:20px; border:1px solid var(--border); }
  .sync-dot { width:7px; height:7px; border-radius:50%; background:var(--text3); transition:background .3s; }
  .sync-dot.ok { background:var(--green); }
  .sync-dot.syncing { background:var(--orange); animation:pulse .8s infinite; }
  .sync-dot.error { background:var(--red); }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

  /* TOAST */
  .toast { position:fixed; bottom:24px; right:24px; background:var(--text); color:#fff; padding:12px 20px; border-radius:10px; font-size:13px; z-index:999; opacity:0; transition:opacity .3s; pointer-events:none; max-width:320px; }
  .toast.show { opacity:1; }
  .toast.ok { background:#1a9e5c; }
  .toast.err { background:#c0392b; }

  /* LAYOUT */
  main { padding:24px 28px; max-width:1440px; margin:0 auto; }
  .section { display:none; }
  .section.active { display:block; }

  /* PAGE TITLE */
  .page-title { font-family:'DM Serif Display',serif; font-size:26px; color:var(--brand); margin-bottom:4px; }
  .page-sub { color:var(--text2); font-size:14px; margin-bottom:20px; }

  /* STATS */
  .stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:20px; }
  .stat-card { background:#fff; border:1px solid var(--border); border-top:3px solid var(--brand); border-radius:12px; padding:16px 18px; }
  .stat-label { font-size:11px; color:var(--text3); text-transform:uppercase; letter-spacing:1px; margin-bottom:6px; }
  .stat-num { font-size:28px; font-weight:600; color:var(--text); }
  .stat-num.c { color:var(--brand); }
  .stat-num.g { color:var(--green); }
  .stat-num.b { color:var(--blue); }

  /* TOOLBAR */
  .toolbar { display:flex; gap:8px; margin-bottom:16px; flex-wrap:wrap; align-items:center; }
  .search-box { flex:1; min-width:200px; background:#fff; border:1px solid var(--border); border-radius:10px; padding:9px 14px; color:var(--text); font-family:'DM Sans',sans-serif; font-size:14px; outline:none; transition:border-color .2s; }
  .search-box:focus { border-color:var(--brand); }
  .search-box::placeholder { color:var(--text3); }
  select.filter-select { background:#fff; border:1px solid var(--border); border-radius:10px; padding:9px 12px; color:var(--text2); font-family:'DM Sans',sans-serif; font-size:14px; outline:none; cursor:pointer; }
  select.filter-select:focus { border-color:var(--brand); }
  select.filter-select option { background:#fff; }

  /* BUTTONS */
  .btn { padding:9px 16px; border-radius:10px; border:none; cursor:pointer; font-family:'DM Sans',sans-serif; font-size:14px; font-weight:500; transition:all .2s; white-space:nowrap; }
  .btn-brand { background:var(--brand); color:#fff; font-weight:600; }
  .btn-brand:hover { background:var(--brand2); }
  .btn-outline { background:transparent; border:1px solid var(--border); color:var(--text2); }
  .btn-outline:hover { border-color:var(--brand); color:var(--brand); }
  .btn-sm { padding:5px 11px; font-size:12px; }
  .btn-red { background:rgba(192,57,43,0.1); color:var(--red); border:1px solid rgba(192,57,43,0.25); }
  .btn-red:hover { background:rgba(192,57,43,0.2); }
  .btn-green { background:rgba(26,158,92,0.1); color:var(--green); border:1px solid rgba(26,158,92,0.25); }

  /* TABLE */
  .table-wrap { overflow-x:auto; border-radius:12px; border:1px solid var(--border); }
  table { width:100%; border-collapse:collapse; }
  thead th { background:var(--surface2); padding:11px 14px; text-align:left; font-size:11px; text-transform:uppercase; letter-spacing:1px; color:var(--text3); border-bottom:1px solid var(--border); white-space:nowrap; }
  tbody tr { border-bottom:1px solid var(--border); transition:background .15s; }
  tbody tr:hover { background:var(--surface2); }
  tbody tr:last-child { border-bottom:none; }
  td { padding:11px 14px; font-size:13px; vertical-align:middle; }
  td.empresa-name { font-weight:600; color:var(--text); max-width:200px; }
  td.contacto-name { color:var(--text2); }

  /* BADGES */
  .badge { display:inline-block; padding:3px 9px; border-radius:20px; font-size:11px; font-weight:600; letter-spacing:.5px; }
  .badge-alto { background:rgba(26,158,92,0.12); color:var(--green); }
  .badge-medio { background:rgba(0,119,168,0.12); color:var(--blue); }
  .badge-bajo { background:rgba(122,170,187,0.12); color:var(--text2); }
  .badge-cliente { background:rgba(0,180,216,0.12); color:var(--brand); }
  .badge-prospecto { background:rgba(0,0,0,0.04); color:var(--text3); border:1px solid var(--border); }

  /* CONTACT */
  .contact-btns { display:flex; gap:5px; }
  .contact-btns a { display:inline-flex; align-items:center; justify-content:center; width:28px; height:28px; border-radius:7px; text-decoration:none; font-size:14px; transition:all .2s; }
  .mail-btn { background:rgba(0,119,168,0.1); color:var(--blue); }
  .mail-btn:hover { background:rgba(0,119,168,0.25); }
  .wa-btn { background:rgba(26,158,92,0.1); color:var(--green); }
  .wa-btn:hover { background:rgba(26,158,92,0.25); }
  .no-email { color:var(--text3); font-size:12px; font-style:italic; }

  /* PAGINATION */
  .pagination { display:flex; align-items:center; justify-content:space-between; margin-top:14px; color:var(--text2); font-size:13px; }
  .page-btns { display:flex; gap:5px; }
  .page-btn { background:#fff; border:1px solid var(--border); color:var(--text2); width:30px; height:30px; border-radius:7px; cursor:pointer; font-size:13px; transition:all .2s; }
  .page-btn:hover, .page-btn.active { border-color:var(--brand); color:var(--brand); }
  .page-btn:disabled { opacity:.3; cursor:default; }

  /* MODAL */
  .modal-overlay { display:none; position:fixed; inset:0; background:rgba(13,31,45,0.5); z-index:200; align-items:center; justify-content:center; padding:20px; }
  .modal-overlay.open { display:flex; }
  .modal { background:#fff; border:1px solid var(--border); border-radius:16px; width:100%; max-width:600px; max-height:90vh; overflow-y:auto; padding:26px; box-shadow:0 8px 40px rgba(0,180,216,0.12); }
  .modal-title { font-family:'DM Serif Display',serif; font-size:22px; color:var(--brand); margin-bottom:18px; }
  .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  .form-full { grid-column:1/-1; }
  .form-group { display:flex; flex-direction:column; gap:5px; }
  .form-label { font-size:11px; color:var(--text2); text-transform:uppercase; letter-spacing:.5px; font-weight:600; }
  .form-input, .form-textarea, .form-select-input { background:var(--surface2); border:1px solid var(--border); border-radius:8px; padding:9px 11px; color:var(--text); font-family:'DM Sans',sans-serif; font-size:14px; outline:none; transition:border-color .2s; width:100%; }
  .form-input:focus, .form-textarea:focus, .form-select-input:focus { border-color:var(--brand); }
  .form-textarea { resize:vertical; min-height:80px; }
  .form-select-input { cursor:pointer; }
  .form-select-input option { background:#fff; }
  .modal-footer { display:flex; justify-content:flex-end; gap:8px; margin-top:20px; }

  /* KANBAN */
  .kanban-board { display:flex; gap:14px; overflow-x:auto; padding-bottom:20px; min-height:500px; }
  .kanban-col { min-width:280px; flex-shrink:0; background:#fff; border:1px solid var(--border); border-radius:14px; padding:14px; display:flex; flex-direction:column; gap:8px; box-shadow:0 1px 6px rgba(0,180,216,0.06); }
  .col-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:6px; }
  .col-title { font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:1px; display:flex; align-items:center; gap:6px; }
  .col-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
  .col-count { background:var(--surface2); color:var(--text2); padding:2px 8px; border-radius:12px; font-size:11px; border:1px solid var(--border); }

  .kanban-card { background:#fff; border:1px solid var(--border); border-left:3px solid var(--brand); border-radius:10px; padding:13px; cursor:pointer; transition:all .2s; position:relative; }
  .kanban-card:hover { border-color:var(--brand); transform:translateY(-1px); box-shadow:0 4px 16px rgba(0,180,216,0.12); }
  .card-title-wrap { display:flex; align-items:flex-start; gap:4px; margin-bottom:5px; }
  .card-title-input { font-size:14px; font-weight:600; color:var(--text); background:transparent; border:none; border-bottom:1px dashed transparent; outline:none; width:100%; font-family:'DM Sans',sans-serif; padding:0; cursor:text; transition:border-color .2s; }
  .card-title-input:focus { border-bottom-color:var(--brand); }
  .card-edit-icon { font-size:11px; color:var(--text3); opacity:0; transition:opacity .2s; flex-shrink:0; margin-top:2px; }
  .kanban-card:hover .card-edit-icon { opacity:1; }
  .card-empresa { font-size:12px; color:var(--brand); margin-bottom:6px; }
  .card-fecha { font-size:11px; color:var(--text3); }
  .card-footer { display:flex; justify-content:space-between; align-items:center; margin-top:8px; }
  .card-tags { display:flex; gap:4px; flex-wrap:wrap; }
  .card-tag { font-size:10px; padding:2px 7px; border-radius:10px; background:var(--surface2); color:var(--text2); border:1px solid var(--border); }

  /* EVENT MODAL */
  .event-modal { max-width:920px; }
  .sheet-tabs-bar { display:flex; align-items:center; gap:0; border-bottom:1px solid var(--border); margin-bottom:14px; overflow-x:auto; }
  .sheet-tab-btn { padding:8px 14px; border:none; background:none; color:var(--text2); font-family:'DM Sans',sans-serif; font-size:13px; cursor:pointer; border-bottom:2px solid transparent; margin-bottom:-1px; white-space:nowrap; transition:all .2s; display:flex; align-items:center; gap:6px; }
  .sheet-tab-btn:hover { color:var(--text); }
  .sheet-tab-btn.active { color:var(--brand); border-bottom-color:var(--brand); font-weight:600; }
  .sheet-tab-btn .tab-close { font-size:10px; color:var(--text3); opacity:0; transition:opacity .15s; padding:0 2px; }
  .sheet-tab-btn:hover .tab-close { opacity:1; }
  .add-sheet-btn { padding:8px 10px; border:none; background:none; color:var(--text3); font-size:16px; cursor:pointer; transition:color .2s; }
  .add-sheet-btn:hover { color:var(--brand); }
  .sheet-content { display:none; }
  .sheet-content.active { display:block; }
  .tab-rename-input { background:transparent; border:none; border-bottom:1px solid var(--brand); outline:none; font-family:'DM Sans',sans-serif; font-size:13px; color:var(--text); padding:0 2px; }
  .section-label { font-size:11px; color:var(--text3); text-transform:uppercase; letter-spacing:1px; margin-bottom:8px; margin-top:14px; font-weight:600; }
  .notas-area { background:var(--surface2); border:1px solid var(--border); border-radius:10px; padding:13px; min-height:120px; color:var(--text); font-family:'DM Sans',sans-serif; font-size:14px; outline:none; width:100%; resize:vertical; line-height:1.6; }
  .notas-area:focus { border-color:var(--brand); }

  /* CHECKLIST */
  .checklist-item { display:flex; align-items:center; gap:9px; padding:9px 11px; background:var(--surface2); border-radius:8px; margin-bottom:7px; border:1px solid var(--border); }
  .checklist-item input[type="checkbox"] { width:15px; height:15px; cursor:pointer; accent-color:var(--brand); flex-shrink:0; }
  .checklist-text { flex:1; font-size:13px; }
  .checklist-text.done { text-decoration:line-through; color:var(--text3); }
  .checklist-meta { font-size:11px; color:var(--text3); white-space:nowrap; }

  /* CRONO */
  .crono-table { width:100%; border-collapse:collapse; }
  .crono-table th { font-size:11px; color:var(--text3); text-transform:uppercase; letter-spacing:1px; padding:8px 11px; text-align:left; border-bottom:1px solid var(--border); font-weight:600; }
  .crono-table td { padding:9px 11px; font-size:13px; border-bottom:1px solid rgba(204,232,245,0.5); }
  .crono-table tr:last-child td { border-bottom:none; }

  /* PROVEEDORES */
  .proveedor-item { display:flex; align-items:center; gap:11px; padding:11px 13px; background:var(--surface2); border-radius:8px; margin-bottom:7px; border:1px solid var(--border); }
  .prov-icon { width:34px; height:34px; background:var(--brand-dim); border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:16px; flex-shrink:0; }
  .prov-info { flex:1; }
  .prov-name { font-size:13px; font-weight:600; }
  .prov-servicio { font-size:12px; color:var(--text2); }

  /* ADD CARD */
  .add-card-btn { width:100%; background:transparent; border:1px dashed var(--border); border-radius:10px; padding:11px; color:var(--text3); cursor:pointer; font-family:'DM Sans',sans-serif; font-size:13px; transition:all .2s; margin-top:4px; }
  .add-card-btn:hover { border-color:var(--brand); color:var(--brand); }

  /* PROGRESS */
  .progress-bar { height:4px; background:var(--surface3); border-radius:2px; margin-top:7px; }
  .progress-fill { height:100%; background:var(--brand); border-radius:2px; transition:width .3s; }

  /* SHARE */
  .share-section-item { display:flex; align-items:center; gap:11px; padding:11px 13px; background:var(--surface2); border:1px solid var(--border); border-radius:10px; margin-bottom:7px; cursor:pointer; transition:all .2s; }
  .share-section-item:hover { border-color:var(--brand); }
  .share-section-item.selected { border-color:var(--brand); background:var(--brand-dim); }
  .share-section-item input[type=checkbox] { accent-color:var(--brand); width:15px; height:15px; flex-shrink:0; }
  .share-section-label { flex:1; font-size:14px; font-weight:500; }
  .share-section-desc { font-size:12px; color:var(--text2); }

  /* INPUT ROW */
  .input-row { display:flex; gap:7px; align-items:flex-end; }
  .input-row .form-input { flex:1; }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width:5px; height:5px; }
  ::-webkit-scrollbar-track { background:var(--surface2); }
  ::-webkit-scrollbar-thumb { background:var(--border); border-radius:3px; }
  ::-webkit-scrollbar-thumb:hover { background:var(--text3); }

  @media(max-width:768px) {
    header { padding:10px 14px; flex-wrap:wrap; gap:8px; }
    main { padding:16px 12px; }
    .stats-row { grid-template-columns:1fr 1fr; }
    .form-grid { grid-template-columns:1fr; }
  }
</style>
</head>
<body>

<header>
  <div class="logo-wrap">
    <img src="data:image/png;base64," alt="Gira Eventos">
    <span class="logo-name">Gira Eventos</span>
    <span class="logo-sub">Sistema de Gestión</span>
  </div>
  <nav>
    <button class="active" onclick="showSection(event,'crm')">📋 CRM Empresas</button>
    <button onclick="showSection(event,'eventos')">🎭 Organización de Eventos</button>
  </nav>
  <div class="sync-badge">
    <div class="sync-dot" id="sync-dot"></div>
    <span id="sync-label">Conectando...</span>
  </div>
</header>

<main>
  <!-- CRM -->
  <section id="crm" class="section active">
    <div class="page-title">Base de Datos — Empresas</div>
    <div class="page-sub">Datos compartidos en tiempo real · Podés filtrar, buscar y contactar directamente</div>
    <div class="stats-row">
      <div class="stat-card"><div class="stat-label">Total registros</div><div class="stat-num c" id="stat-total">—</div></div>
      <div class="stat-card"><div class="stat-label">Clientes activos</div><div class="stat-num g" id="stat-clientes">—</div></div>
      <div class="stat-card"><div class="stat-label">Potencial ALTO</div><div class="stat-num c" id="stat-altos">—</div></div>
      <div class="stat-card"><div class="stat-label">Mostrando</div><div class="stat-num b" id="stat-mostrando">—</div></div>
    </div>
    <div class="toolbar">
      <input type="text" class="search-box" placeholder="🔍  Buscar empresa, contacto o mail..." id="crm-search" oninput="applyFilters()">
      <select class="filter-select" id="f-cliente" onchange="applyFilters()">
        <option value="">Todos</option>
        <option value="si">✅ Clientes</option>
        <option value="no">🔲 Prospectos</option>
      </select>
      <select class="filter-select" id="f-potencial" onchange="applyFilters()">
        <option value="">Potencial</option>
        <option value="ALTO">🟢 Alto</option>
        <option value="MEDIO">🔵 Medio</option>
        <option value="BAJO">⚪ Bajo</option>
      </select>
      <select class="filter-select" id="f-area" onchange="applyFilters()">
        <option value="">Área</option>
        <option value="RRHH">RRHH</option>
        <option value="Marketing">Marketing</option>
        <option value="Administración">Administración</option>
        <option value="Comercial">Comercial</option>
      </select>
      <button class="btn btn-brand" onclick="openAddModal()">+ Agregar empresa</button>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr>
          <th>Empresa</th><th>Contacto</th><th>Email</th><th>Teléfono</th>
          <th>Estado</th><th>Potencial</th><th>Área</th><th>Notas</th>
          <th>Contactar</th><th></th>
        </tr></thead>
        <tbody id="crm-tbody"></tbody>
      </table>
    </div>
    <div class="pagination">
      <span id="page-info">—</span>
      <div class="page-btns" id="page-btns"></div>
    </div>
  </section>

  <!-- EVENTOS -->
  <section id="eventos" class="section">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:18px;">
      <div>
        <div class="page-title">Organización de Eventos</div>
        <div class="page-sub">Gestioná cada evento en tiempo real con todo el equipo</div>
      </div>
      <button class="btn btn-brand" onclick="openNewEventModal()">+ Nuevo evento</button>
    </div>
    <div class="kanban-board" id="kanban-board"></div>
  </section>
</main>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- MODAL: Empresa -->
<div class="modal-overlay" id="add-modal">
  <div class="modal">
    <div class="modal-title" id="add-modal-title">Nueva Empresa</div>
    <div class="form-grid">
      <div class="form-group form-full"><label class="form-label">Empresa *</label><input type="text" class="form-input" id="f-empresa" placeholder="Nombre de la empresa"></div>
      <div class="form-group"><label class="form-label">Contacto</label><input type="text" class="form-input" id="f-contacto" placeholder="Nombre y apellido"></div>
      <div class="form-group"><label class="form-label">Área</label>
        <select class="form-select-input" id="f-area-input">
          <option value="">Sin especificar</option>
          <option>RRHH</option><option>Marketing</option><option>Administración</option>
          <option>Comercial</option><option>Asistente Gerencia</option><option>Prensa</option><option>Otro</option>
        </select>
      </div>
      <div class="form-group"><label class="form-label">Email</label><input type="email" class="form-input" id="f-email" placeholder="mail@empresa.com"></div>
      <div class="form-group"><label class="form-label">Teléfono / WhatsApp</label><input type="text" class="form-input" id="f-telefono" placeholder="11 1234-5678"></div>
      <div class="form-group"><label class="form-label">¿Es cliente?</label>
        <select class="form-select-input" id="f-es-cliente">
          <option value="false">🔲 Prospecto</option>
          <option value="true">✅ Cliente</option>
        </select>
      </div>
      <div class="form-group"><label class="form-label">Potencial</label>
        <select class="form-select-input" id="f-potencial-input">
          <option value="">Sin definir</option>
          <option value="ALTO">🟢 Alto</option>
          <option value="MEDIO">🔵 Medio</option>
          <option value="BAJO">⚪ Bajo</option>
        </select>
