function renderChecklistHTML(ev) {
  const items = ev.checklist || [];
  const done = items.filter(c=>c.done).length;
  return (items.length ? `
    <div style="margin-bottom:10px;">
      <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--text2);margin-bottom:5px;">
        <span>${done} de ${items.length} completadas</span><span>${items.length?Math.round(done/items.length*100):0}%</span>
      </div>
      <div class="progress-bar"><div class="progress-fill" style="width:${items.length?Math.round(done/items.length*100):0}%"></div></div>
    </div>` : '') +
  items.map((c,i) => `
    <div class="checklist-item">
      <input type="checkbox" ${c.done?'checked':''} onchange="toggleCheck(${i})">
      <div class="checklist-text ${c.done?'done':''}">${c.texto}</div>
      <div class="checklist-meta">${c.persona?'👤 '+c.persona:''} ${c.fecha?'· '+formatDate(c.fecha):''}</div>
      <button class="btn btn-red btn-sm" onclick="removeCheck(${i})">✕</button>
    </div>`).join('');
}

function renderChecklist(ev) {
  const el = document.getElementById('checklist-list');
  if (el) el.innerHTML = renderChecklistHTML(ev);
}

async function addChecklistItem() {
  const texto = document.getElementById('new-check-text').value.trim(); if (!texto) return;
  const ev = eventsData.find(e => e.id === currentEventId);
  ev.checklist = ev.checklist || [];
  ev.checklist.push({ texto, persona: document.getElementById('new-check-persona').value.trim(), fecha: document.getElementById('new-check-fecha').value, done: false });
  ['new-check-text','new-check-persona','new-check-fecha'].forEach(id => document.getElementById(id).value='');
  await saveEventDB(ev); renderChecklist(ev);
}

async function toggleCheck(i) {
  const ev = eventsData.find(e => e.id === currentEventId);
  ev.checklist[i].done = !ev.checklist[i].done;
  await saveEventDB(ev); renderChecklist(ev);
}

async function removeCheck(i) {
  const ev = eventsData.find(e => e.id === currentEventId);
  ev.checklist.splice(i,1);
  await saveEventDB(ev); renderChecklist(ev);
}

// ═══════════════════════════════════════════
//  CRONOGRAMA
// ═══════════════════════════════════════════
function renderCronoHTML(type, items) {
  return items.map((r,i) => `
    <tr>
      <td>${formatDate(r.dia)}</td><td>${r.hora}</td><td>${r.asunto}</td>
      ${type==='interno'?`<td style="color:var(--text2)">${r.notas||''}</td>`:''}
      <td><button class="btn btn-red btn-sm" onclick="removeCrono('${type}',${i})">✕</button></td>
    </tr>`).join('') ||
  `<tr><td colspan="${type==='interno'?5:4}" style="color:var(--text3);text-align:center;padding:18px;">Sin ítems aún</td></tr>`;
}

function renderCronoTable(type, items) {
  const el = document.getElementById(`crono-${type}-body`);
  if (el) el.innerHTML = renderCronoHTML(type, items);
}

async function addCronoItem(type) {
  const pre = type === 'interno' ? 'ci' : 'cc';
  const asunto = document.getElementById(`${pre}-asunto`).value.trim(); if (!asunto) return;
  const ev = eventsData.find(e => e.id === currentEventId);
  const key = type === 'interno' ? 'cronoInterno' : 'cronoCliente';
  ev[key] = ev[key] || [];
  const item = { dia: document.getElementById(`${pre}-dia`).value, hora: document.getElementById(`${pre}-hora`).value.trim(), asunto };
  if (type === 'interno') item.notas = document.getElementById('ci-notas').value.trim();
  ev[key].push(item);
  ev[key].sort((a,b) => (a.dia||'') < (b.dia||'') ? -1 : 1);
  [`${pre}-dia`,`${pre}-hora`,`${pre}-asunto`].forEach(id => document.getElementById(id).value='');
  if (type==='interno') document.getElementById('ci-notas').value='';
  await saveEventDB(ev); renderCronoTable(type, ev[key]);
}

async function removeCrono(type, i) {
  const ev = eventsData.find(e => e.id === currentEventId);
  const key = type === 'interno' ? 'cronoInterno' : 'cronoCliente';
  ev[key].splice(i,1);
  await saveEventDB(ev); renderCronoTable(type, ev[key]);
}

function downloadCrono(type) {
  const ev = eventsData.find(e => e.id === currentEventId);
  const key = type === 'interno' ? 'cronoInterno' : 'cronoCliente';
  const items = ev[key] || [];
  const label = type === 'interno' ? 'Cronograma Interno' : 'Cronograma Cliente';
  const html = `<!DOCTYPE html><html><head><meta charset="UTF-8"><style>body{font-family:Arial,sans-serif;padding:40px;color:#0d1f2d}h1{color:#00b4d8;border-bottom:2px solid #00b4d8;padding-bottom:10px}h2{color:#3a6070;font-size:16px;margin-bottom:18px}table{width:100%;border-collapse:collapse}th{background:#f4fafd;padding:10px 13px;text-align:left;border-bottom:2px solid #cce8f5;font-size:11px;text-transform:uppercase;letter-spacing:1px}td{padding:10px 13px;border-bottom:1px solid #e6f4fb;font-size:14px}</style></head><body>
  <h1>Gira Eventos</h1><h2>${label} — ${ev.nombre}${ev.empresa?' ('+ev.empresa+')':''}</h2>
  <table><thead><tr><th>Día</th><th>Horario</th><th>Asunto</th>${type==='interno'?'<th>Notas</th>':''}</tr></thead><tbody>
  ${items.map(r=>`<tr><td>${formatDate(r.dia)}</td><td>${r.hora}</td><td>${r.asunto}</td>${type==='interno'?`<td>${r.notas||''}</td>`:''}</tr>`).join('')}
  </tbody></table></body></html>`;
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([html],{type:'text/html'}));
  a.download = `${label.replace(/ /g,'_')}_${ev.nombre.replace(/ /g,'_')}.html`;
  a.click();
}

// ═══════════════════════════════════════════
//  PROVEEDORES
// ═══════════════════════════════════════════
function renderProveedoresHTML(ev) {
  const iconos = {'Sonido':'🔊','Iluminación':'💡','Catering':'🍽','Fotografía':'📸','Video':'🎬','Decoración':'🌸','DJ':'🎵','Logística':'🚚'};
  return (ev.proveedores||[]).map((p,i) => `
    <div class="proveedor-item">
      <div class="prov-icon">${iconos[p.servicio]||'🤝'}</div>
      <div class="prov-info"><div class="prov-name">${p.nombre}</div><div class="prov-servicio">${p.servicio}${p.contacto?' · '+p.contacto:''}</div></div>
      <button class="btn btn-red btn-sm" onclick="removeProveedor(${i})">✕</button>
    </div>`).join('') || '<p style="color:var(--text3);font-size:13px;">Sin proveedores asignados aún</p>';
}

function renderProveedores(ev) {
  const el = document.getElementById('proveedores-list');
  if (el) el.innerHTML = renderProveedoresHTML(ev);
}

async function addProveedor() {
  const nombre = document.getElementById('prov-nombre').value.trim(); if (!nombre) return;
  const ev = eventsData.find(e => e.id === currentEventId);
  ev.proveedores = ev.proveedores || [];
  ev.proveedores.push({ nombre, servicio: document.getElementById('prov-servicio').value.trim(), contacto: document.getElementById('prov-contacto').value.trim() });
  ['prov-nombre','prov-servicio','prov-contacto'].forEach(id => document.getElementById(id).value='');
  await saveEventDB(ev); renderProveedores(ev);
}

async function removeProveedor(i) {
  const ev = eventsData.find(e => e.id === currentEventId);
  ev.proveedores.splice(i,1);
  await saveEventDB(ev); renderProveedores(ev);
}

// ═══════════════════════════════════════════
//  SHARE
// ═══════════════════════════════════════════
function openShareModal() {
  const ev = eventsData.find(e => e.id === currentEventId); if (!ev) return;
  const sections = [
    { id:'general', label:'📋 General', desc:'Descripción y notas internas' },
    { id:'checklist', label:'✅ Checklist', desc:'Lista de tareas' },
    { id:'crono-interno', label:'🗓 Cronograma Interno', desc:'Para el equipo' },
    { id:'crono-cliente', label:'📤 Cronograma Cliente', desc:'Para enviar al cliente' },
    { id:'proveedores', label:'🤝 Proveedores', desc:'Proveedores contratados' },
    ...(ev.sheets||[]).map(s => ({ id:s.id, label:s.label, desc:'Hoja de notas libre' }))
  ];
  document.getElementById('share-sections-list').innerHTML = sections.map(s => `
    <div class="share-section-item" onclick="toggleShareSection(this)">
      <input type="checkbox" name="share-sec" value="${s.id}" onclick="event.stopPropagation()">
      <div><div class="share-section-label">${s.label}</div><div class="share-section-desc">${s.desc}</div></div>
    </div>`).join('');
  document.getElementById('share-modal').classList.add('open');
}

function toggleShareSection(el) {
  el.classList.toggle('selected');
  el.querySelector('input[type=checkbox]').checked = el.classList.contains('selected');
}

function generateShareDoc() {
  const ev = eventsData.find(e => e.id === currentEventId);
  const sel = [...document.querySelectorAll('input[name="share-sec"]:checked')].map(c=>c.value);
  if (!sel.length) { toast('Seleccioná al menos una sección','err'); return; }
  let html = `<!DOCTYPE html><html><head><meta charset="UTF-8"><style>body{font-family:Georgia,serif;padding:48px;color:#0d1f2d;max-width:800px;margin:0 auto;line-height:1.7}h1{color:#00b4d8;font-size:28px;border-bottom:2px solid #00b4d8;padding-bottom:12px;margin-bottom:4px}h2{color:#0077a8;font-size:18px;margin-top:30px;margin-bottom:10px;padding-bottom:5px;border-bottom:1px solid #cce8f5}h3{color:#00b4d8;font-size:13px;margin:0 0 4px;font-weight:600}.meta{color:#7aaabb;font-size:13px;margin-bottom:30px}table{width:100%;border-collapse:collapse;margin:10px 0}th{background:#f4fafd;padding:9px 12px;text-align:left;border-bottom:2px solid #cce8f5;font-size:11px;text-transform:uppercase;letter-spacing:1px;font-family:Arial}td{padding:9px 12px;border-bottom:1px solid #e6f4fb;font-size:14px}.check-item{display:flex;gap:10px;padding:7px 0;border-bottom:1px solid #f0f8fd}.check-done{text-decoration:line-through;color:#aaa}.prov-item{padding:7px 0;border-bottom:1px solid #f0f8fd}.notes-box{background:#f4fafd;border:1px solid #cce8f5;border-radius:8px;padding:14px;white-space:pre-wrap;font-size:14px;line-height:1.8}</style></head><body>
  <h1>Gira Eventos</h1><div class="meta">${ev.empresa?'🏢 '+ev.empresa+' · ':''}${ev.fecha?'📅 '+formatDate(ev.fecha)+' · ':''}${ev.nombre}</div>`;
  if (sel.includes('general') && (ev.descripcion||ev.notas)) {
    html += `<h2>📋 General</h2>`;
    if (ev.descripcion) html += `<p>${ev.descripcion}</p>`;
    if (ev.notas) html += `<h3 style="margin-top:14px;">Notas internas</h3><p>${ev.notas}</p>`;
  }
  if (sel.includes('checklist') && (ev.checklist||[]).length) {
    html += `<h2>✅ Checklist</h2>`;
    ev.checklist.forEach(c => { html += `<div class="check-item"><span>${c.done?'☑':'☐'}</span><span class="${c.done?'check-done':''}">${c.texto}</span>${c.persona?`<span style="color:#7aaabb;font-size:12px;margin-left:auto">👤 ${c.persona}</span>`:''}</div>`; });
  }
  if (sel.includes('crono-interno') && (ev.cronoInterno||[]).length) {
    html += `<h2>🗓 Cronograma Interno</h2><table><thead><tr><th>Día</th><th>Horario</th><th>Asunto</th><th>Notas</th></tr></thead><tbody>`;
    ev.cronoInterno.forEach(r => { html += `<tr><td>${formatDate(r.dia)}</td><td>${r.hora}</td><td>${r.asunto}</td><td>${r.notas||''}</td></tr>`; });
    html += `</tbody></table>`;
  }
  if (sel.includes('crono-cliente') && (ev.cronoCliente||[]).length) {
    html += `<h2>📤 Cronograma</h2><table><thead><tr><th>Día</th><th>Horario</th><th>Asunto</th></tr></thead><tbody>`;
    ev.cronoCliente.forEach(r => { html += `<tr><td>${formatDate(r.dia)}</td><td>${r.hora}</td><td>${r.asunto}</td></tr>`; });
    html += `</tbody></table>`;
  }
  if (sel.includes('proveedores') && (ev.proveedores||[]).length) {
    html += `<h2>🤝 Proveedores</h2>`;
    ev.proveedores.forEach(p => { html += `<div class="prov-item"><strong>${p.nombre}</strong> — ${p.servicio}${p.contacto?' · '+p.contacto:''}</div>`; });
  }
  (ev.sheets||[]).forEach(s => {
    if (sel.includes(s.id) && s.content) html += `<h2>${s.label}</h2><div class="notes-box">${s.content}</div>`;
  });
  html += `</body></html>`;
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([html],{type:'text/html'}));
  a.download = `${ev.nombre.replace(/ /g,'_')}_compartido.html`;
  a.click();
  closeModal('share-modal');
}

