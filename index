//  EVENT DETAIL — SHEETS
// ═══════════════════════════════════════════
const BUILTIN_SHEETS = [
  { id:'general',       label:'📋 General',        type:'general' },
  { id:'checklist',     label:'✅ Checklist',       type:'checklist' },
  { id:'crono-interno', label:'🗓 Crono. Interno',  type:'crono-interno' },
  { id:'crono-cliente', label:'📤 Crono. Cliente',  type:'crono-cliente' },
  { id:'proveedores',   label:'🤝 Proveedores',     type:'proveedores' },
];

function openEventDetail(id) {
  const ev = eventsData.find(e => e.id === id); if (!ev) return;
  currentEventId = id; currentSheetIdx = 0;
  document.getElementById('ed-title').value = ev.nombre || '';
  document.getElementById('ed-empresa').value = ev.empresa || '';
  document.getElementById('ed-fecha').value = ev.fecha || '';
  document.getElementById('ed-estado-select').value = ev.estado;
  renderSheets(ev);
  document.getElementById('event-detail-modal').classList.add('open');
}

function getAllSheets(ev) {
  return [...BUILTIN_SHEETS, ...(ev.sheets || [])];
}

function renderSheets(ev) {
  const all = getAllSheets(ev);
  document.getElementById('sheet-tabs-bar').innerHTML =
    all.map((s,i) => `
      <button class="sheet-tab-btn ${i===currentSheetIdx?'active':''}" onclick="switchSheet(${i})" id="stab-${i}">
        ${s.type==='blank'
          ? `<input class="tab-rename-input" value="${(s.label||'').replace(/"/g,'&quot;')}" onclick="event.stopPropagation()" onblur="renameSheet(${i},this.value)" onkeydown="if(event.key==='Enter')this.blur()" style="width:${Math.max(60,(s.label||'').length*8)}px">`
          : s.label}
        ${s.type==='blank' ? `<span class="tab-close" onclick="event.stopPropagation();removeSheet(${i})">✕</span>` : ''}
      </button>`).join('') +
    `<button class="add-sheet-btn" onclick="addBlankSheet()" title="Nueva hoja en blanco">＋</button>`;

  document.getElementById('sheet-contents').innerHTML =
    all.map((s,i) => `<div class="sheet-content ${i===currentSheetIdx?'active':''}" id="scontent-${i}">${renderSheetContent(s,ev,i)}</div>`).join('');
}

function switchSheet(i) {
  const ev = eventsData.find(e => e.id === currentEventId);
  currentSheetIdx = i; renderSheets(ev);
}

async function addBlankSheet() {
  const ev = eventsData.find(e => e.id === currentEventId);
  ev.sheets = ev.sheets || [];
  ev.sheets.push({ id:'blank-'+Date.now(), label:'Nueva hoja', type:'blank', content:'' });
  await saveEventDB(ev);
  currentSheetIdx = BUILTIN_SHEETS.length + ev.sheets.length - 1;
  renderSheets(ev);
}

async function renameSheet(idx, val) {
  const ev = eventsData.find(e => e.id === currentEventId);
  const bi = idx - BUILTIN_SHEETS.length;
  if (bi >= 0 && ev.sheets && ev.sheets[bi]) {
    ev.sheets[bi].label = val.trim() || ev.sheets[bi].label;
    await saveEventDB(ev);
  }
}

async function removeSheet(idx) {
  if (!confirm('¿Eliminar esta hoja?')) return;
  const ev = eventsData.find(e => e.id === currentEventId);
  const bi = idx - BUILTIN_SHEETS.length;
  if (bi >= 0 && ev.sheets) {
    ev.sheets.splice(bi,1);
    await saveEventDB(ev);
    currentSheetIdx = Math.min(currentSheetIdx, getAllSheets(ev).length - 1);
    renderSheets(ev);
  }
}

async function saveBlankSheet(idx, val) {
  const ev = eventsData.find(e => e.id === currentEventId);
  const bi = idx - BUILTIN_SHEETS.length;
  if (bi >= 0 && ev.sheets && ev.sheets[bi]) {
    ev.sheets[bi].content = val;
    await saveEventDB(ev);
  }
}

