function applyFilters() {
  const q = document.getElementById('crm-search').value.toLowerCase();
  const fc = document.getElementById('f-cliente').value;
  const fp = document.getElementById('f-potencial').value;
  const fa = document.getElementById('f-area').value;
  filtered = crmData.filter(c => {
    const matchQ = !q || (c.empresa||'').toLowerCase().includes(q) || (c.contacto||'').toLowerCase().includes(q) || (c.email||'').toLowerCase().includes(q);
    const matchC = !fc || (fc === 'si' ? c.esCliente : !c.esCliente);
    const matchP = !fp || c.potencial === fp;
    const matchA = !fa || c.area === fa;
    return matchQ && matchC && matchP && matchA;
  });
  currentPage = 1;
  renderTable();
  updateStats();
}

function updateStats() {
  document.getElementById('stat-total').textContent = crmData.length;
  document.getElementById('stat-clientes').textContent = crmData.filter(c => c.esCliente).length;
  document.getElementById('stat-altos').textContent = crmData.filter(c => c.potencial === 'ALTO').length;
  document.getElementById('stat-mostrando').textContent = filtered.length;
}

function renderTable() {
  const tbody = document.getElementById('crm-tbody');
  const start = (currentPage - 1) * PER_PAGE;
  const page = filtered.slice(start, start + PER_PAGE);
  tbody.innerHTML = page.map(c => {
    const emailClean = (c.email||'').replace(/mailto:/g,'').split('/')[0].trim().split(' ')[0].trim();
    const telClean = (c.telefono||'').replace(/[^0-9+]/g,'');
    const bp = c.potencial === 'ALTO' ? 'badge-alto' : c.potencial === 'MEDIO' ? 'badge-medio' : c.potencial === 'BAJO' ? 'badge-bajo' : '';
    const notasTrunc = (c.notas||'').length > 38 ? (c.notas||'').substring(0,38) + '...' : (c.notas||'');
    return `<tr>
      <td class="empresa-name" title="${c.empresa}">${(c.empresa||'').substring(0,34)}${(c.empresa||'').length>34?'…':''}</td>
      <td class="contacto-name">${c.contacto || '<span class="no-email">—</span>'}</td>
      <td style="font-size:12px;color:var(--text2);max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${emailClean ? `<span title="${emailClean}">${emailClean.substring(0,28)}${emailClean.length>28?'…':''}</span>` : '<span class="no-email">—</span>'}</td>
      <td style="font-size:12px;color:var(--text3);">${(c.telefono||'').substring(0,20)||'—'}</td>
      <td><span class="badge ${c.esCliente ? 'badge-cliente' : 'badge-prospecto'}">${c.esCliente ? '✅ Cliente' : 'Prospecto'}</span></td>
      <td>${bp ? `<span class="badge ${bp}">${c.potencial}</span>` : '—'}</td>
      <td style="font-size:12px;color:var(--text2);">${c.area || '—'}</td>
      <td style="font-size:12px;color:var(--text3);max-width:140px;" title="${c.notas||''}">${notasTrunc || '—'}</td>
      <td><div class="contact-btns">
        ${emailClean ? `<a class="mail-btn" href="mailto:${emailClean}" title="Enviar mail">✉</a>` : ''}
        ${telClean ? `<a class="wa-btn" href="https://wa.me/${telClean.replace('+','')}" target="_blank" title="WhatsApp">📱</a>` : ''}
      </div></td>
      <td>
        <button class="btn btn-outline btn-sm" onclick="openEditModal(${c.id})">✏️</button>
        <button class="btn btn-red btn-sm" onclick="confirmDeleteCompany(${c.id})" style="margin-left:3px;">🗑</button>
      </td>
    </tr>`;
  }).join('');
  renderPagination();
  document.getElementById('page-info').textContent = `${start+1}–${Math.min(start+PER_PAGE, filtered.length)} de ${filtered.length}`;
}

function renderPagination() {
  const total = Math.ceil(filtered.length / PER_PAGE);
  const btns = document.getElementById('page-btns');
  let html = `<button class="page-btn" onclick="goPage(${currentPage-1})" ${currentPage===1?'disabled':''}>‹</button>`;
  for (let i = 1; i <= total; i++) {
    if (i === 1 || i === total || (i >= currentPage-2 && i <= currentPage+2)) {
      html += `<button class="page-btn ${i===currentPage?'active':''}" onclick="goPage(${i})">${i}</button>`;
    } else if (i === currentPage-3 || i === currentPage+3) {
      html += `<span style="color:var(--text3);padding:0 3px;">…</span>`;
    }
  }
  html += `<button class="page-btn" onclick="goPage(${currentPage+1})" ${currentPage===total?'disabled':''}>›</button>`;
  btns.innerHTML = html;
}

function goPage(p) {
  const total = Math.ceil(filtered.length / PER_PAGE);
  if (p < 1 || p > total) return;
  currentPage = p; renderTable();
}

